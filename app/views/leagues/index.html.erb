<section class="hero is-primary is-medium">
  <div class="hero-body">
    <div class="container has-text-centered">
      <h1 class="title is-1">Leagues</h1>
      <p class="subtitle">Join a competitive league and prove your skills</p>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <% if @leagues.any? %>
      <div class="columns is-multiline">
        <% @leagues.each do |league| %>
          <div class="column is-4">
            <div class="card">
              <div class="card-content">
                <p class="title is-4"><%= league.name %></p>
                <p class="subtitle is-6">
                  <span class="tag <%= league.active? ? 'is-success' : 'is-info' %>">
                    <%= league.active? ? 'Active' : 'Signups Open' %>
                  </span>
                </p>
                <p class="content">
                  <%= league.description || "No description available." %>
                </p>
              </div>
              <footer class="card-footer">
                <%= link_to "View League", league, class: "card-footer-item" %>
              </footer>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="has-text-centered">
        <p class="is-size-4 has-text-grey">No leagues available at the moment.</p>
        <p class="has-text-grey-light">Check back soon!</p>
      </div>
    <% end %>
  </div>
</section>
